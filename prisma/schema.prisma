generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:../dev.db"
}

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  blogs       Blog[]
  tools       Tool[]
}

model Tool {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  description     String
  longDescription String?
  categoryId      String
  metaTitle       String?
  metaDescription String?
  iconName        String?
  isPopular       Boolean  @default(false)
  instructions    String
  faqs            String
  exampleInput    String?
  componentName   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  category        Category @relation(fields: [categoryId], references: [id])
}

model Blog {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  categoryId      String
  metaTitle       String?
  metaDescription String?
  featuredImage   String?
  content         String
  isPublished     Boolean  @default(false)
  publishDate     DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  category        Category @relation(fields: [categoryId], references: [id])
}

model AdPlacement {
  id         String   @id @default(cuid())
  location   String   @unique
  adSlot     String?
  customHtml String?
  isEnabled  Boolean  @default(true)
  updatedAt  DateTime @updatedAt
}

model GlobalConfig {
  id              String  @id @default("default")
  siteName        String  @default("TakeTheTools")
  siteDescription String?
  metaTitle       String?
  metaDescription String?
  ogImage         String?
  analyticsId     String?
  twitterHandle   String?
  adSenseId       String?
}
